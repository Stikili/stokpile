# ─────────────────────────────────────────────────────────────
# Stokpile — Production Environment Variables
# Copy this file to .env.production.local and fill in values.
# NEVER commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────

# Supabase (required)
# Found in: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Sentry error tracking (optional but recommended in production)
# Found in: sentry.io → Project → Settings → Client Keys (DSN)
VITE_SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/your-project-id

# App version — used by Sentry for release tracking (optional)
# Typically set automatically in CI/CD from git tag or commit SHA
VITE_APP_VERSION=1.0.0

# ─────────────────────────────────────────────────────────────
# Paystack (payment links for contributions)
# Found in: dashboard.paystack.com → Settings → API Keys & Webhooks
# ─────────────────────────────────────────────────────────────
# PAYSTACK_SECRET_KEY=sk_live_...          ← set on Supabase Edge Function env
# APP_URL=https://stokpilev1.vercel.app    ← redirect after payment

# ─────────────────────────────────────────────────────────────
# Twilio WhatsApp (contribution & payout notifications)
# Found in: console.twilio.com → Account Info
# Sender: Twilio sandbox (+14155238886) or approved WhatsApp sender
# ─────────────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   ← Supabase env
# TWILIO_AUTH_TOKEN=your-auth-token                       ← Supabase env
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886              ← Supabase env

# ─────────────────────────────────────────────────────────────
# Push Notifications (VAPID keys)
# Generate with: npx web-push generate-vapid-keys
# ─────────────────────────────────────────────────────────────
# VITE_VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   ← Supabase env
# VAPID_SUBJECT=mailto:admin@yourdomain.com                           ← Supabase env
